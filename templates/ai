#!/usr/bin/env bash

set -euo pipefail

STANDARDS_DIR=".ai-harness/.ai-standards"
WORKFLOW="$STANDARDS_DIR/scripts/ai_workflow.sh"

if [[ ! -f "$WORKFLOW" ]]; then
  printf 'error: %s not found\n' "$WORKFLOW" >&2
  printf 'hint: run git submodule update --init --recursive, then bootstrap again\n' >&2
  exit 1
fi

exec bash "$WORKFLOW" "$@"
